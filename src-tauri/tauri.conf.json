{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tester Desk",
  "version": "0.1.0",
  "identifier": "com.aranya.testerdesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Tester Desk",
        "width": 1400,
        "height": 900,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "center": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "backgroundColor": "#1e1e1e"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
